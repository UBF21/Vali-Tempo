<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0</TargetFrameworks>
        <RootNamespace>Vali_Time</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Title>Vali-Time</Title>
        <Authors>Felipe Rafael Montenegro Morriberon</Authors>
        <Description>
            Vali-Time is a lightweight .NET library for converting and managing time units, including milliseconds, seconds, minutes, hours, days, weeks, months, and years. It offers a precise and flexible API for time conversions, summations, breakdowns, and human-readable formatting. ValiDate extends the library with date arithmetic, period boundaries, validations, and a comprehensive Quarter API. With support for full precision calculations, optional rounding, cultural formatting, and seamless dependency injection integration, Vali-Time is ideal for any .NET application requiring accurate time and date handling.
        </Description>
        <PackageProjectUrl>https://github.com/UBF21/Vali-Time</PackageProjectUrl>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/UBF21/Vali-Time</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>
            Vali-Time v1.0.0 — initial release:
            - Time unit conversions with full decimal precision: milliseconds, seconds, minutes, hours, days, weeks, months, and years.
            - SumTimes: aggregate multiple time values across different units into a single result.
            - FormatTime: human-readable output with configurable decimal places and CultureInfo support.
            - GetBestUnit: automatic detection of the most appropriate time unit for a given value.
            - ToTimeSpan: interoperability bridge to System.TimeSpan.
            - Breakdown: decompose a duration into its constituent units (hours, minutes, seconds, milliseconds).
            - ValiDate: date arithmetic (Add, Subtract, Diff), period boundaries (StartOf, EndOf), validations (IsBefore, IsAfter, IsWeekend, IsSamePeriod), and an extended Quarter API (QuarterName, ProgressInQuarter, DaysRemainingInQuarter, and more).
            - Designed for seamless integration with .NET dependency injection via IValiTime and IValiDate interfaces.
        </PackageReleaseNotes>
        <PackageTags>Time;converter;formatting;utility;dotnet;date;calendar;quarter;range</PackageTags>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <Copyright>Copyright © 2025 - FM. All rights reserved.</Copyright>
        <Version>1.0.0</Version>
        <PackageIcon>logo-Vali-Time.png</PackageIcon>
        <PackageId>Vali-Time</PackageId>
        <Product>Vali-Time</Product>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    </ItemGroup>

    <ItemGroup>
        <None Include="logo-Vali-Time.png">
            <Pack>True</Pack>
            <PackagePath></PackagePath>
        </None>
    </ItemGroup>

</Project>
